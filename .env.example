OPENAI_API_KEY=your_openai_api_key_here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Qdrant (port 6333 khi chạy Docker, 6335 nếu dùng mapping cũ)
QDRANT_URL=http://localhost:6333

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LangSmith Tracing (tuỳ chọn)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=FPT_Policy_GraphRAG

# PostgreSQL (Docker)
POSTGRES_URL=postgresql+asyncpg://fpt:fpt_password@localhost:5433/fpt_chat

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Reranker
RERANKER_TOP_N=3

# Cache TTL
SESSION_TTL_SECONDS=86400
RAG_CACHE_TTL_SECONDS=3600
